{
  "expo": {
    "name": "RefillX",
    "slug": "refillx",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EEE8E0"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.refillx.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#EEE8E0"
      },
      "package": "com.refillx.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "scheme": "refillx",
    "experiments": {
      "typedRoutes": true
    }
  }
}
